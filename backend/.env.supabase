# Supabase Configuration
# Replace these with your actual Supabase project credentials

# Database connection (from Supabase Dashboard → Database → Connection string)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Direct connection (bypassing connection pooler if needed)
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true

# Or use Supabase pooled connection for serverless:
# DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Redis (can use Upstash or local)
REDIS_URL=redis://localhost:6379/0

# For serverless Redis, use Upstash:
# REDIS_URL=rediss://default:[PASSWORD]@[HOST]:6379

# Kafka (can use Upstash or Confluent Cloud)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# OpenWeatherMap API (get free key at openweathermap.org/api)
OPENWEATHER_API_KEY=

# Security
SECRET_KEY=change-me-in-production-strong-random-key

# Environment
ENVIRONMENT=production
DEBUG=false

# Supabase specific
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
