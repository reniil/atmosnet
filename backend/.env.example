# Database
DATABASE_URL=postgresql://atmosnet:atmosnet@localhost:5432/atmosnet

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_OBSERVATIONS_TOPIC=observations.raw
KAFKA_VALIDATED_TOPIC=observations.validated

# OpenWeatherMap API (optional for local dev)
# Get free API key at https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Security
SECRET_KEY=change-me-in-production-local-dev-only

# Environment
ENVIRONMENT=development
DEBUG=true
